{
    "name": "veejay/api",
    "description": "Universal API webkit",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-simplexml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.4"
    },
    "autoload": {
        "psr-4": {
            "veejay\\api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "test\\": "test/"
        }
    }
}
